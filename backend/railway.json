{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "bash start.sh",
    "healthcheckPath": "/api/categories",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE"
  }
}
